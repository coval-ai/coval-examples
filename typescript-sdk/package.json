{
  "name": "@coval/sdk",
  "version": "0.3.0",
  "description": "Typed TypeScript client for the Coval evaluation platform API.",
  "license": "MIT",
  "author": "Coval <support@coval.dev>",
  "homepage": "https://docs.coval.dev/api-reference",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coval-ai/coval-examples.git",
    "directory": "typescript-sdk"
  },
  "bugs": {
    "url": "https://github.com/coval-ai/coval-examples/issues"
  },
  "keywords": [
    "coval",
    "voice-ai",
    "evaluation",
    "openapi",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generated": {
      "types": "./dist/generated/index.d.ts",
      "import": "./dist/generated/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:list-agents": "tsx examples/list-agents.ts",
    "example:submit-conversation": "tsx examples/submit-conversation.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
